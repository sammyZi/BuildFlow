# ─────────────────────────────────────────────────────────────
# Supabase Configuration
# ─────────────────────────────────────────────────────────────

# Public keys (safe to expose to the browser — prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only key — BYPASSES Row Level Security. NEVER expose to the client.
# Required by API routes (lib/supabase/server.ts).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─────────────────────────────────────────────────────────────
# Google Gemini API (Backend / server-side ONLY)
# ─────────────────────────────────────────────────────────────

# Provide EITHER variable. GEMINI_API_KEY is read as a fallback for the
# Vercel AI SDK's default GOOGLE_GENERATIVE_AI_API_KEY.
GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# Optional: override the default model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────

# Public base URL of the deployment, used for share links and redirects.
# e.g. http://localhost:3000 in dev, https://yourdomain.com in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
